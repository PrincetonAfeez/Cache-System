{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/cachelab/schema/simulation_result.schema.json",
  "title": "CacheLab Simulation or Benchmark Result",
  "description": "Generic schema for persisted/serialized simulation and benchmark result records.",
  "type": "object",
  "additionalProperties": true,
  "required": ["policy", "pattern", "capacity", "requests", "hits", "misses", "hit_ratio"],
  "properties": {
    "policy": { "type": "string", "enum": ["lru", "lfu", "fifo"] },
    "pattern": { "type": "string", "minLength": 1 },
    "capacity": { "type": "integer", "minimum": 1 },
    "requests": { "type": "integer", "minimum": 0 },
    "hits": { "type": "integer", "minimum": 0 },
    "misses": { "type": "integer", "minimum": 0 },
    "hit_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
    "elapsed_seconds": { "type": "number", "minimum": 0 },
    "ops_per_second": { "type": "number", "minimum": 0 }
  }
}
